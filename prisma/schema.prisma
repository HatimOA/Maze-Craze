generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// =========================
// PLAYER
// =========================
model Player {
  id       Int    @id @default(autoincrement())
  email    String @unique @db.VarChar(255)
  password String @db.VarChar(255)
  name     String @db.VarChar(255)

  states          State[]
  recommendations StateRecommendation[]

  @@map("player")
}

// =========================
// STATE (MAZE)
// =========================
model State {
  state_id String @id @db.VarChar(64)

  player_id Int
  player    Player @relation(fields: [player_id], references: [id])

  p1_x Int
  p1_y Int
  p2_x Int
  p2_y Int
  r_x  Int
  r_y  Int

  robbers_left Int

  // 0 = high visibility (many walls visible)
  // 3 = low visibility (few walls visible)
  visibility Int @default(0)

  imageUrl String? @db.Text

  rewards         Reward[]
  recommendations StateRecommendation[]

  @@index([player_id])
  @@map("state")
}

// =========================
// ACTIONS (AGENT BEHAVIORS)
// =========================
model Action {
  action_id       Int    @id @default(autoincrement())
  agents_behavior String @db.VarChar(50)

  rewards Reward[]

  @@map("actions")
}

// =========================
// REWARD
// =========================
model Reward {
  reward_id Int @id @default(autoincrement())

  state_id  String
  action_id Int
  value     Int

  state  State  @relation(fields: [state_id], references: [state_id], onDelete: Cascade)
  action Action @relation(fields: [action_id], references: [action_id])

  @@unique([state_id, action_id])
  @@index([state_id])
  @@map("rewards")
}

// =========================
// RECOMMENDATIONS
// =========================
model StateRecommendation {
  id Int @id @default(autoincrement())

  player_id Int
  state_id  String

  player Player @relation(fields: [player_id], references: [id])
  state  State  @relation(fields: [state_id], references: [state_id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([player_id, state_id])
  @@index([state_id])
  @@map("state_recommendations")
}
